# ---------------------------------------------------------------------------
# World Cup 2026 AI Predictor - environment configuration
# Copy this file to ".env" and fill in the values you have.
# The app runs WITHOUT any keys using clearly-labelled mock data.
# ---------------------------------------------------------------------------

# Server port (optional)
PORT=3000

# ---------------------------------------------------------------------------
# FOOTBALL DATA SOURCE
# ---------------------------------------------------------------------------
# FOOTBALL_API_PROVIDER picks which provider module is used.
# Supported values:
#   auto          -> let the data-source selector decide (recommended)
#   api-football  -> API-Football / API-Sports (https://www.api-football.com)
#   football-data -> football-data.org
#   sportmonks    -> Sportmonks
#   thesportsdb   -> TheSportsDB (works with the free shared test key)
#   mock          -> force the bundled mock fixtures (no network, no key)
FOOTBALL_API_PROVIDER=auto

# API key for the selected provider. Leave blank to fall back to mock data.
FOOTBALL_API_KEY=

# Optional. Override the provider base URL. Leave blank to use the default
# base URL baked into the chosen provider module.
FOOTBALL_API_BASE_URL=

# ---------------------------------------------------------------------------
# AI PROVIDER
# ---------------------------------------------------------------------------
# AI_PROVIDER chooses the model backend that writes the prediction.
# Supported values:
#   anthropic  -> Anthropic Claude API (recommended)
#   openai     -> OpenAI Chat Completions API
#   mock       -> deterministic local heuristic (no key, clearly labelled)
AI_PROVIDER=anthropic

# API key for the chosen AI provider. Leave blank to fall back to the local
# heuristic prediction engine (clearly labelled as not using a live model).
AI_API_KEY=

# Model id for the chosen AI provider.
#   anthropic example: claude-opus-4-8
#   openai example:    gpt-4o-mini
AI_MODEL=claude-opus-4-8
